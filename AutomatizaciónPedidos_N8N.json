      "parameters": {
        "jsCode": "// Normaliza números sin importar si vienen con , o . como decimal\nfunction num(valor) {\n  if (valor === null || valor === undefined || valor === '') return 0;\n  // Convierte a texto, quita espacios, y reemplaza coma decimal por punto\n  let s = String(valor).trim();\n  // Si tiene coma como decimal (ej \"1.234,56\" o \"49,9\"), normalizar\n  if (s.includes(',')) {\n    s = s.replace(/\\./g, '').replace(',', '.'); // quita separador de miles, coma→punto\n  }\n  return Number(s) || 0;\n}\n\n// 1. Trae el inventario completo (salida del nodo Google Sheets)\nconst inventario = $('Get row(s) in sheet').all().map(i => i.json);\n\n// 2. Trae el pedido del cliente (salida del nodo Code de parseo)\nconst pedido = $('Code in JavaScript').all().map(i => i.json);\n\n// 3. Para cada producto pedido, cruzar contra el inventario\nconst resultado = pedido.map(item => {\n\n  // CASO AMBIGUO: la IA marcó varias opciones posibles\n  if (item.ambiguo && item.ambiguo.length > 0) {\n    const opciones = item.ambiguo.map(sku =>\n      inventario.find(inv => inv.SKU === sku)\n    ).filter(Boolean);\n    return {\n      json: {\n        estado: 'AMBIGUO',\n        producto_cliente: item.producto,\n        cantidad: item.cantidad,\n        opciones: opciones.map(o => ({\n          sku: o.SKU, nombre: o.Producto, precio: o.Precio_Unitario_USD\n        }))\n      }\n    };\n  }\n\n  // CASO NO EXISTE: la IA no encontró SKU\n  if (!item.sku) {\n    return {\n      json: { estado: 'NO_EXISTE', producto_cliente: item.producto, cantidad: item.cantidad }\n    };\n  }\n\n  // CASO CLARO: buscar el SKU en el inventario\n  const prod = inventario.find(inv => inv.SKU === item.sku);\n\n  if (!prod) {\n    return { json: { estado: 'NO_EXISTE', producto_cliente: item.producto, cantidad: item.cantidad } };\n  }\n\n  // Verificar stock\n  const stockSuficiente = num(prod.Stock_Actual) >= num(item.cantidad);\n\n  return {\n    json: {\n      estado: stockSuficiente ? 'DISPONIBLE' : 'SIN_STOCK',\n      sku: prod.SKU,\n      nombre: prod.Producto,\n      cantidad_pedida: item.cantidad,\n      stock_actual: num(prod.Stock_Actual),\n      precio: num(prod.Precio_Unitario_USD),\n      sustituto_1: prod.Sustituto_1 || null,\n      sustituto_2: prod.Sustituto_2 || null\n    }\n  };\n});\n\nreturn resultado;"
      },
