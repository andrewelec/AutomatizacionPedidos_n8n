    {
      "parameters": {
        "jsCode": "// Inventario completo (para consultar el stock de los sustitutos)\nconst inventario = $('Get row(s) in sheet').all().map(i => i.json);\n\nfunction num(v) {\n  if (v === null || v === undefined || v === '') return 0;\n  let s = String(v).trim();\n  if (s.includes(',')) s = s.replace(/\\./g, '').replace(',', '.');\n  return Number(s) || 0;\n}\n\nconst item = $json;  // producto sin stock que entra a esta rama\n\n// Recoge los SKUs sustitutos (1 y 2) que existan\nconst skusSustitutos = [item.sustituto_1, item.sustituto_2].filter(Boolean);\n\n// Para cada sustituto, busca su info y verifica stock\nconst alternativas = skusSustitutos\n  .map(sku => inventario.find(inv => inv.SKU === sku))\n  .filter(Boolean)\n  .filter(prod => num(prod.Stock_Actual) > 0)   // solo los que tienen stock\n  .map(prod => ({\n    sku: prod.SKU,\n    nombre: prod.Producto,\n    precio: num(prod.Precio_Unitario_USD),\n    stock: num(prod.Stock_Actual)\n  }));\n\nreturn [{\n  json: {\n    estado: 'SIN_STOCK',\n    producto_original: item.nombre,\n    cantidad_pedida: item.cantidad_pedida,\n    stock_disponible: item.stock_actual,\n    hay_alternativas: alternativas.length > 0,\n    alternativas: alternativas\n  }\n}];\n\n\n// Construir botones para cada alternativa con stock\nconst botones = alternativas.map(a => ([{\n  text: `${a.nombre} — $${a.precio}`,\n  callback_data: `SUST|${a.sku}|${item.cantidad_pedida}`\n}]));\n\n// Botón de cancelar\nbotones.push([{ text: '❌ Cancelar', callback_data: 'CANCELAR' }]);\n\nreturn [{\n  json: {\n    estado: 'SIN_STOCK',\n    producto_original: item.nombre,\n    cantidad_pedida: item.cantidad_pedida,\n    stock_disponible: item.stock_actual,\n    hay_alternativas: alternativas.length > 0,\n    alternativas: alternativas,\n    botones: botones   // ← NUEVO: estructura lista para Telegram\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
