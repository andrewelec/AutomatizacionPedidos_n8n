      "parameters": {
        "jsCode": "// Toma el texto que devolvió Gemini\nlet respuesta = $input.first().json.content.parts[0].text;\n// Limpia posibles ``` o etiquetas markdown que a veces añade el modelo\nrespuesta = respuesta.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// Convierte el texto en JSON real\nconst pedido = JSON.parse(respuesta);\n\n// Devuelve un ítem por cada producto del pedido\nreturn pedido.map(item => ({ json: item }));"
      },
      "type": "n8n-nodes-base.code",
