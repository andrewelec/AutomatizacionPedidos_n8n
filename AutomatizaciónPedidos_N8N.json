      "parameters": {
        "jsCode": "const data = $('Telegram Trigger').first().json.callback_query.data;\nfunction num(v){ if(v==null||v==='')return 0; let s=String(v).trim(); if(s.includes(','))s=s.replace(/\\./g,'').replace(',','.'); return Number(s)||0; }\n\nif (data === 'CANCELAR' || data === 'NADA') {\n  return [{ json: {\n    accion: 'CANCELAR',\n    chat_id: $('Telegram Trigger').first().json.callback_query.message.chat.id\n  }}];\n}\n\nconst [accion, sku, cantidad] = data.split('|');\nconst inventario = $input.all().map(i => i.json);\nconst prod = inventario.find(inv => inv.SKU === sku);\n\nreturn [{ json: {\n  accion: 'SUST',\n  sku: prod.SKU,\n  nombre: prod.Producto,\n  cantidad: num(cantidad),\n  precio: num(prod.Precio_Unitario_USD),\n  chat_id: $('Telegram Trigger').first().json.callback_query.message.chat.id\n}}];"
      },
